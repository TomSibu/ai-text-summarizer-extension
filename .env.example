# Example environment configuration for the AI Summarizer backend

# Base URL of the summarization server used by the Chrome extension
BACKEND_URL=http://localhost:3000

# API key for your LLM provider (e.g., OpenAI, Anthropic)
GEMINI_API_KEY=your-api-key-here

# Optional: model name or configuration
GEMINI_AI_MODEL=gemini-2.5-flash

# Optional: port for the local Node.js server
PORT=3000
